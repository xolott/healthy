# Copy to `.env` in this directory (`apps/admin`). Nuxt loads `.env`, `.env.local`, and `.env.[mode]` automatically (see https://nuxt.com/docs/getting-started/configuration#environment-variables).

NODE_ENV=development

# Healthy API origin (must match where `pnpm --filter api dev` listens — default port 3001).
# Use the same hostname you open admin with (`localhost` vs `127.0.0.1`). If they differ, the browser will not send the session cookie on HTTP (SameSite=Lax).
NUXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Optional: disable vue-tsc during `nuxt dev` (CI / Playwright stacks sometimes set this).
# NUXT_DISABLE_TYPECHECK=1
