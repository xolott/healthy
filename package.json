{
  "name": "healthy-monorepo",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "overrides": {
      "postgres": "3.4.8"
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "turbo format",
    "test": "turbo test",
    "clean": "turbo clean && node tooling/scripts/clean.mjs",
    "doctor": "node tooling/scripts/doctor.mjs",
    "verify:auth-contracts": "bash tooling/scripts/verify-auth-contracts.sh"
  },
  "devDependencies": {
    "concurrently": "9.2.1",
    "eslint": "10.2.1",
    "prettier": "3.8.3",
    "turbo": "2.9.6",
    "typescript": "6.0.3"
  }
}
