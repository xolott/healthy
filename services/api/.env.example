# Fastify (@fastify/env). Copy to `.env` in this directory (`services/api`).
NODE_ENV=development
HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info

# Comma-separated origins or `*` (see src/config/env.ts)
CORS_ORIGIN=*

# Optional for boot without DB (health-only). Required for routes that use Drizzle.
# Example when Postgres runs via repo root `docker compose up`:
DATABASE_URL=postgres://healthy:healthy@127.0.0.1:5432/healthy_dev
