{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "pretypecheck": "pnpm --filter @healthy/db build",
    "pretest": "pnpm --filter @healthy/db build",
    "dev": "tsx watch ./src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node ./dist/main.js",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "pnpm --filter @healthy/db db:migrate",
    "db:recreate": "tsx ./scripts/recreate-db.ts",
    "reference-food:import-usda-json": "tsx ./scripts/import-usda-reference-food-json.ts",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "clean": "node ../../tooling/scripts/clean-api-dist.mjs"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/env": "6.0.0",
    "@fastify/sensible": "6.0.4",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.6",
    "@healthy/db": "workspace:*",
    "argon2": "0.44.0",
    "drizzle-orm": "0.44.7",
    "fastify": "5.8.5",
    "stream-chain": "^3.6.1",
    "stream-json": "^2.1.0"
  },
  "devDependencies": {
    "@healthy/eslint-config": "workspace:*",
    "@healthy/prettier-config": "workspace:*",
    "@healthy/typescript-config": "workspace:*",
    "@types/node": "25.6.0",
    "eslint": "10.2.1",
    "postgres": "3.4.8",
    "prettier": "3.8.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
