{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "dev": "tsx watch ./src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node ./dist/main.js",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "pnpm --filter @healthy/db db:migrate",
    "db:recreate": "tsx ./scripts/recreate-db.ts",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "clean": "node ../../tooling/scripts/clean-api-dist.mjs"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/env": "6.0.0",
    "@fastify/sensible": "6.0.4",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.6",
    "@healthy/db": "workspace:*",
    "argon2": "0.44.0",
    "fastify": "5.8.5"
  },
  "devDependencies": {
    "@healthy/eslint-config": "workspace:*",
    "@healthy/prettier-config": "workspace:*",
    "@healthy/typescript-config": "workspace:*",
    "@testcontainers/postgresql": "11.14.0",
    "@types/node": "25.6.0",
    "drizzle-orm": "0.45.2",
    "eslint": "10.2.1",
    "postgres": "3.4.9",
    "prettier": "3.8.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
